{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.py": {
      "includeFiles": "api/heart_model.pkl",
      "excludeFiles": "{src/**,dist/**,public/**,node_modules/**,heart_disease_data.csv,heart_disease_prediction.py,README.md,readme.md,package*.json,vite.config.js,.vscode/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
